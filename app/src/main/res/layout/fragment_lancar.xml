<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="➕  Registrar nova venda"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text"
            android:layout_marginBottom="16dp"/>

        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Categoria -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CATEGORIA"
                    android:textSize="10sp"
                    android:textColor="@color/muted"
                    android:textAllCaps="true"
                    android:layout_marginBottom="6dp"/>

                <Spinner
                    android:id="@+id/spinner_categoria"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="14dp"/>

                <!-- Cliente -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CLIENTE (OPCIONAL)"
                    android:textSize="10sp"
                    android:textColor="@color/muted"
                    android:textAllCaps="true"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/et_cliente"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="12dp"
                    android:hint="Nome do cliente..."
                    android:textColor="@color/text"
                    android:textColorHint="@color/muted"
                    android:inputType="textPersonName"
                    android:layout_marginBottom="14dp"/>

                <!-- Valor -->
                <TextView
                    android:id="@+id/tv_label_valor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VALOR (R$)"
                    android:textSize="10sp"
                    android:textColor="@color/muted"
                    android:textAllCaps="true"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/et_valor"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="12dp"
                    android:hint="0,00"
                    android:textColor="@color/text"
                    android:textColorHint="@color/muted"
                    android:inputType="numberDecimal"
                    android:layout_marginBottom="14dp"/>

                <!-- Data -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATA"
                    android:textSize="10sp"
                    android:textColor="@color/muted"
                    android:textAllCaps="true"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/et_data"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="12dp"
                    android:hint="AAAA-MM-DD"
                    android:textColor="@color/text"
                    android:textColorHint="@color/muted"
                    android:inputType="date"
                    android:layout_marginBottom="20dp"/>

                <!-- Botão -->
                <Button
                    android:id="@+id/btn_registrar"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Registrar venda"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_primary"
                    android:textColor="@color/white"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
